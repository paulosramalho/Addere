NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/addere?sslmode=require
JWT_SECRET=troque-por-um-segredo-longo
SEED_ADMIN_EMAIL=admin@addere.com.br
SEED_ADMIN_PASSWORD=troque-por-uma-senha-temporaria
SEED_ADMIN_NAME=Administrador Addere
SEED_ADMIN_RESET=false
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://addere.vercel.app
EMAIL_FROM=Addere <noreply@addere.com.br>
RESEND_API_KEY=
ADMIN_WHATSAPP=
SENTRY_DSN=

# ── Banco Inter (cobrança PJ) ─────────────────────────────────────────────────
# INTER_MODE: mock | sandbox | production (default: mock)
INTER_MODE=mock
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
INTER_CONTA_CORRENTE=
# Certificado mTLS (uma das opções abaixo)
# Para Render: cole o conteúdo do .crt/.key em base64 nas vars *_B64
INTER_CERT_B64=
INTER_KEY_B64=
# Para dev local: caminhos absolutos para os arquivos
INTER_CERT_PATH=
INTER_KEY_PATH=
# Webhook de notificação de pagamento (opcional)
INTER_WEBHOOK_SECRET=

# ── C6 Bank (cobrança PJ) ─────────────────────────────────────────────────────
# Status: scaffold — modo mock funcional. Modo sandbox/production exige
# contrato corporativo com o C6 Bank e revisão da implementação real.
C6_MODE=mock
C6_CLIENT_ID=
C6_CLIENT_SECRET=
C6_CONTA_CORRENTE=
# Endpoints (opcional — defaults internos seguem o padrão BaaS C6)
C6_SANDBOX_URL=
C6_PRODUCTION_URL=
